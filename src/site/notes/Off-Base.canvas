---
{"dg-publish":true,"permalink":"/off-base.canvas/","contentClasses":"canvas-page","tags":["gardenEntry"],"dg-note-properties":{}}
---

<div id="Off-Basecanvas" class="canvas-wrapper hide">
	<svg class="canvas-background">
		<defs>
			<pattern id="canvas-grid-Off-Basecanvas" width="25" height="25" patternUnits="userSpaceOnUse">
				<circle r="1.5" cx="12.5" cy="12.5"></circle>
			</pattern>
		</defs>
		<rect width="100%" height="100%" fill="url(#canvas-grid-Off-Basecanvas)"></rect>
	</svg>
	<div class="canvas">
		<svg class="canvas-edges-container" style="position:absolute;width:1px;height:1px;overflow:visible;">
			<defs><filter x="-0.1" y="-0.1" width="1.2" height="1.3" id="edge-label-bg">
			<feFlood flood-color="var(--background-primary)" flood-opacity="1" result="bg"/>
			<feMerge>
				<feMergeNode in="bg"/>
				<feMergeNode in="SourceGraphic"/>
			</feMerge>
		</filter></defs>
		</svg>
		<div class="canvas-node canvas-node-file canvas-node-image " data-node-id="9090c0394ce4ab1f" style="transform: translate(640px, -581px); width: 296px; height: 400px; ">
	<div class="canvas-node-container">
		<div class="canvas-node-content image-embed">
			<img src="/img/user/New%20folder%20(3)/29178485_1306376222795648_2998508448217300992_n.jpg" alt="29178485_1306376222795648_2998508448217300992_n.jpg" loading="lazy" />
		</div>
	</div>
</div>
